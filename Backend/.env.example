# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── FFmpeg (required for Smart Engine) ───────────────────────────────────────
# Install FFmpeg: https://ffmpeg.org/download.html
# Windows: winget install FFmpeg  |  Mac: brew install ffmpeg
# Verify: ffmpeg -version  and  ffprobe -version
# Supabase Storage bucket "videos" will be auto-created on first upload

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key   # Use Service Role, NOT anon key

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_minimum_32_characters

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_MASTER_PASSWORD=your_secure_admin_password

# ─── Redis (for BullMQ job queue) ─────────────────────────────────────────────
# Local: redis://localhost:6379
# Cloud: get from upstash.com (free tier works)
REDIS_URL=redis://localhost:6379

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Get from: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# Create a $12/mo recurring price in Stripe dashboard, paste the price_id here:
STRIPE_PRO_PRICE_ID=price_your_pro_price_id

# ─── Platform OAuth ───────────────────────────────────────────────────────────
# YouTube: console.cloud.google.com → APIs → YouTube Data API v3 → Credentials
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret
YOUTUBE_REDIRECT_URI=http://localhost:5000/api/accounts/youtube/callback

# TikTok: developers.tiktok.com → app dashboard
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_REDIRECT_URI=http://localhost:5000/api/accounts/tiktok/callback

# Instagram: developers.facebook.com → Instagram Basic Display
INSTAGRAM_APP_ID=your_instagram_app_id
INSTAGRAM_APP_SECRET=your_instagram_app_secret
INSTAGRAM_REDIRECT_URI=http://localhost:5000/api/accounts/instagram/callback
